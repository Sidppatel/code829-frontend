{
  "name": "code829-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:public": "pnpm --filter @code829/public dev",
    "dev:admin": "pnpm --filter @code829/admin dev",
    "dev:staff": "pnpm --filter @code829/staff dev",
    "dev:developer": "pnpm --filter @code829/developer dev",
    "build": "pnpm -r build",
    "build:public": "pnpm --filter @code829/public build",
    "build:admin": "pnpm --filter @code829/admin build",
    "build:staff": "pnpm --filter @code829/staff build",
    "build:developer": "pnpm --filter @code829/developer build",
    "lint": "pnpm -r lint",
    "preview:public": "pnpm --filter @code829/public preview",
    "preview:admin": "pnpm --filter @code829/admin preview",
    "preview:staff": "pnpm --filter @code829/staff preview",
    "preview:developer": "pnpm --filter @code829/developer preview",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.48.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.8"
  }
}
